DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/hermanprompt
# DATABASE_PUBLIC_URL can be used instead of DATABASE_URL if that is the value
# your host provides. The backend accepts either name and will normalize
# postgres:// and postgresql:// URLs to the psycopg driver automatically.
APP_ENV=development
HOST=0.0.0.0
PORT=8010
LOG_LEVEL=INFO
HERMANPROMPT_UI_URL=http://localhost:5173
PORTAL_UI_URL=http://localhost:5174
HERMANPROMPT_LAUNCH_SECRET=replace-with-shared-launch-secret
LAUNCH_TOKEN_TTL_SECONDS=3600
PASSWORD_RESET_TOKEN_TTL_SECONDS=1800
DEV_SHOW_RESET_LINKS=true
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
